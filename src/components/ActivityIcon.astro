---
import type { ActivityIconName } from '../content/translations';

type Props = {
  name: ActivityIconName;
};

const { name } = Astro.props;
---

<span class="activity-icon" aria-hidden="true">
  <svg viewBox="0 0 32 32" fill="none">
    {name === 'coffee' && (
      <>
        <path d="M7 11h15v8a6 6 0 0 1-6 6h-3a6 6 0 0 1-6-6v-8Z" />
        <path d="M22 14h2.5a3.5 3.5 0 0 1 0 7H22M11 7c0-1.3 1.4-1.5 1.4-3M17 7c0-1.3 1.4-1.5 1.4-3" />
      </>
    )}
    {name === 'family' && (
      <>
        <circle cx="11" cy="10" r="3.2" /><circle cx="22" cy="12" r="2.6" />
        <path d="M5 25c.5-6 2.5-9 6-9s5.5 3 6 9M17 25c.3-4.5 2-7 5-7s4.7 2.5 5 7" />
      </>
    )}
    {name === 'walk' && (
      <>
        <circle cx="19" cy="6.5" r="2.6" />
        <path d="m15 27 2.2-8-4.4-4.2M17.2 19l4 3.5M12.8 14.8l3-5 5.5 3.2 4.2-.7M7 27l5.8-7.2" />
      </>
    )}
    {name === 'tip' && (
      <>
        <path d="M10 20c-2-1.8-3-4.1-3-6.7A9 9 0 0 1 25 13c0 2.8-1.3 5.2-3.4 7l-1.5 1.5h-8.5L10 20Z" />
        <path d="M12 25h8M13.5 28h5M16 3v2M4.5 8.5l2 1M27.5 8.5l-2 1" />
      </>
    )}
    {name === 'sport' && (
      <>
        <circle cx="16" cy="16" r="11" />
        <path d="m12 13 4-3 4 3-1.5 4.8h-5L12 13ZM16 10V5M12 13 7.5 11M20 13l4.5-2M13.5 17.8 10 22M18.5 17.8 22 22" />
      </>
    )}
    {name === 'idea' && (
      <>
        <path d="m16 4 1.7 5.1L23 8l-3.6 4.1 3.6 4.1-5.3-1.1L16 20l-1.7-4.9L9 16.2l3.6-4.1L9 8l5.3 1.1L16 4Z" />
        <path d="M7 22c4.2 2.6 13.8 2.6 18 0M11 27c3 1.3 7 1.3 10 0" />
      </>
    )}
  </svg>
</span>

<style>
  .activity-icon {
    display: grid;
    width: 3rem;
    height: 3rem;
    margin-bottom: 1.3rem;
    place-items: center;
    border: 1px solid rgb(23 59 95 / 16%);
    border-radius: 52% 48% 45% 55%;
    background: var(--paper);
    color: var(--navy);
    transform: rotate(-2deg);
  }

  svg {
    width: 1.8rem;
    height: 1.8rem;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.65;
  }
</style>
