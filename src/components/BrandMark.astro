---
type Props = {
  subtitle: string;
};

const { subtitle } = Astro.props;
---

<a class="brand" href="#top" aria-label={`N4 ${subtitle}`}>
  <img class="brand__mark" src="/logo-mark.svg" width="48" height="48" alt="" />
  <span class="brand__words">
    <strong>N4 French</strong>
    <span>{subtitle}</span>
  </span>
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--navy);
    text-decoration: none;
  }

  .brand__mark {
    width: 3rem;
    height: 3rem;
    transform: rotate(-4deg);
  }

  .brand__words {
    display: grid;
    line-height: 1;
  }

  .brand__words strong {
    font-family: var(--display);
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }

  .brand__words span {
    margin-top: 0.18rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
