---
import { Picture } from 'astro:assets';
import heroImage from '../assets/n4-hero-v2.png';
import parentsImage from '../assets/n4-parents.jpg';
import type { SiteContent } from '../content/translations';
import BaseLayout from '../layouts/BaseLayout.astro';
import ActivityIcon from './ActivityIcon.astro';
import BrandMark from './BrandMark.astro';
import LanguageSwitch from './LanguageSwitch.astro';

type Props = {
  content: SiteContent;
};

const { content } = Astro.props;
const whatsappUrl = 'https://chat.whatsapp.com/DjSmPJHzEXy06EWamiZ9sr?s=cl&p=i&ilr=4';
---

<BaseLayout {...content}>
  <a class="skip-link" href="#main">{content.skipLink}</a>

  <div class="page-shell" id="top">
    <header class="site-header">
      <BrandMark subtitle={content.brandSubtitle} />

      <nav class="main-nav" aria-label={content.nav.label}>
        <a href="#community">{content.nav.community}</a>
        <a href="#activities">{content.nav.activities}</a>
        <a href="#parents">{content.nav.parents}</a>
      </nav>

      <div class="header-actions">
        <LanguageSwitch locale={content.locale} label={content.languageLabel} />
        <a class="button button--small" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
          {content.nav.join}
        </a>
      </div>
    </header>

    <main id="main">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero__art">
          <span class="tape tape--top" aria-hidden="true"></span>
          <Picture
            src={heroImage}
            formats={['avif', 'webp']}
            fallbackFormat="jpg"
            widths={[720, 1100, 1500]}
            sizes="(max-width: 760px) 92vw, 1180px"
            alt={content.hero.imageAlt}
            loading="eager"
            fetchpriority="high"
          />
          <p class="photo-note">{content.hero.imageNote}</p>
        </div>

        <div class="hero__copy">
          <p class="eyebrow">{content.hero.eyebrow}</p>
          <h1 id="hero-title">
            {content.hero.titleStart}
            {' '}
            <span>{content.hero.titleAccent}</span>
          </h1>
          <p class="hero__description">{content.hero.description}</p>
          <div class="hero__actions">
            <a class="button" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2a9.8 9.8 0 0 0-8.45 14.75L2.2 21.8l5.18-1.35A9.8 9.8 0 1 0 12 2Zm0 17.8a7.9 7.9 0 0 1-4.03-1.1l-.29-.17-3.08.8.82-3-.19-.3A7.94 7.94 0 1 1 12 19.8Zm4.36-5.94c-.24-.12-1.4-.69-1.62-.77-.22-.08-.38-.12-.54.12-.16.24-.62.77-.76.93-.14.16-.28.18-.52.06-.24-.12-1.01-.37-1.92-1.18a7.22 7.22 0 0 1-1.33-1.65c-.14-.24-.01-.37.1-.49.11-.1.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.4-.54-.41h-.46a.89.89 0 0 0-.64.3c-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.59 4.11 3.63.58.25 1.03.4 1.38.51.58.18 1.1.16 1.52.1.46-.07 1.4-.58 1.6-1.13.2-.56.2-1.03.14-1.13-.06-.1-.22-.16-.46-.28Z" />
              </svg>
              {content.hero.primaryCta}
            </a>
            <a class="text-link" href="#community">{content.hero.secondaryCta}<span aria-hidden="true">↓</span></a>
          </div>
          <p class="trust-note"><span aria-hidden="true">♥</span> {content.hero.trustNote}</p>
        </div>

      </section>

      <section class="welcome section" id="community" aria-labelledby="welcome-title">
        <div class="section-heading section-heading--offset">
          <p class="eyebrow">{content.welcome.kicker}</p>
          <h2 id="welcome-title">{content.welcome.title}</h2>
        </div>
        <div class="welcome__body">
          {content.welcome.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          <aside class="handwritten-note">
            <span aria-hidden="true">↳</span>
            {content.welcome.note}
          </aside>
        </div>
      </section>

      <section class="activities section" id="activities" aria-labelledby="activities-title">
        <div class="section-heading section-heading--centred">
          <p class="eyebrow">{content.activities.kicker}</p>
          <h2 id="activities-title">{content.activities.title}</h2>
          <p>{content.activities.introduction}</p>
        </div>
        <div class="activity-grid">
          {content.activities.items.map((item, index) => (
            <article class:list={['activity-card', `activity-card--${index + 1}`]}>
              <ActivityIcon name={item.icon} />
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="parents section" id="parents" aria-labelledby="parents-title">
        <div class="parents__visual">
          <div class="photo-frame photo-frame--parents">
            <span class="tape tape--side" aria-hidden="true"></span>
            <Picture
              src={parentsImage}
              formats={['avif', 'webp']}
              widths={[520, 760, 1000]}
              sizes="(max-width: 760px) 92vw, 44vw"
              alt={content.parents.imageAlt}
              loading="lazy"
            />
          </div>
        </div>
        <div class="parents__copy">
          <p class="eyebrow">{content.parents.kicker}</p>
          <h2 id="parents-title">{content.parents.title}</h2>
          {content.parents.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          <p class="parents__note"><span aria-hidden="true">✓</span>{content.parents.note}</p>
        </div>
      </section>

      <section class="closing section" aria-labelledby="closing-title">
        <span class="closing__doodle closing__doodle--left" aria-hidden="true">✦</span>
        <span class="closing__doodle closing__doodle--right" aria-hidden="true">♡</span>
        <p class="eyebrow">{content.closing.eyebrow}</p>
        <h2 id="closing-title">{content.closing.title}</h2>
        <p>{content.closing.description}</p>
        <a class="button button--light" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2a9.8 9.8 0 0 0-8.45 14.75L2.2 21.8l5.18-1.35A9.8 9.8 0 1 0 12 2Zm0 17.8a7.9 7.9 0 0 1-4.03-1.1l-.29-.17-3.08.8.82-3-.19-.3A7.94 7.94 0 1 1 12 19.8Zm4.36-5.94c-.24-.12-1.4-.69-1.62-.77-.22-.08-.38-.12-.54.12-.16.24-.62.77-.76.93-.14.16-.28.18-.52.06-.24-.12-1.01-.37-1.92-1.18a7.22 7.22 0 0 1-1.33-1.65c-.14-.24-.01-.37.1-.49.11-.1.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.3-.74-1.78-.2-.47-.4-.4-.54-.41h-.46a.89.89 0 0 0-.64.3c-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.59 4.11 3.63.58.25 1.03.4 1.38.51.58.18 1.1.16 1.52.1.46-.07 1.4-.58 1.6-1.13.2-.56.2-1.03.14-1.13-.06-.1-.22-.16-.46-.28Z" />
          </svg>
          {content.closing.cta}
        </a>
        <small>{content.closing.footnote}</small>
      </section>
    </main>

    <footer class="site-footer">
      <BrandMark subtitle={content.brandSubtitle} />
      <p>{content.footer.line}</p>
      <p>{content.footer.location}</p>
    </footer>
  </div>
</BaseLayout>
